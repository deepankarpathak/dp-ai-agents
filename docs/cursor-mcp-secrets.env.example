# Copy to ~/.cursor/mcp-secrets.env (chmod 600). Do not commit.
# Values are examples only — use your real URLs and rotate any leaked tokens.

export JIRA_URL="https://yourcompany.atlassian.net"
export JIRA_EMAIL="you@company.com"
export JIRA_TOKEN="your-atlassian-api-token"

# Often same as JIRA_* for Atlassian Cloud
export CONFLUENCE_URL="https://yourcompany.atlassian.net/wiki"
export CONFLUENCE_USERNAME="${JIRA_EMAIL}"
export CONFLUENCE_API_TOKEN="${JIRA_TOKEN}"

export REDASH_URL="https://your-redash.example.com"
export REDASH_API_KEY="your-redash-api-key"
