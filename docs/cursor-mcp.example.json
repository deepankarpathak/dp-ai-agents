{
  "mcpServers": {
    "mcp-atlassian": {
      "command": "/bin/bash",
      "args": [
        "-lc",
        "set -a && [ -f \"$HOME/.cursor/mcp-secrets.env\" ] && . \"$HOME/.cursor/mcp-secrets.env\" && set +a && exec /Users/YOUR_USER/.local/bin/uvx --python 3.12 mcp-atlassian"
      ]
    },
    "redash": {
      "command": "/bin/bash",
      "args": [
        "-lc",
        "set -a && [ -f \"$HOME/.cursor/mcp-secrets.env\" ] && . \"$HOME/.cursor/mcp-secrets.env\" && set +a && exec /Users/YOUR_USER/.nvm/versions/node/v24.14.0/bin/npx -y @suthio/redash-mcp"
      ]
    },
    "gmail": {
      "command": "/Users/YOUR_USER/.nvm/versions/node/v24.14.0/bin/npx",
      "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"]
    },
    "whatsapp": {
      "command": "/Users/YOUR_USER/.local/bin/uv",
      "args": [
        "--directory",
        "/Users/YOUR_USER/whatsapp-mcp/whatsapp-mcp-server",
        "run",
        "main.py"
      ]
    }
  }
}
