# Copy to .env and fill in values. Do not commit .env.

# ── Frontend → Backend (fix "Backend error: 404") ──
# If Share/Score or Connectors show 404: start the backend (npm run start:backend).
# Backend defaults to port 5000; the React app proxies /api/* to it.
# If your backend runs on another port (e.g. 5001), set:
# REACT_APP_API_URL=http://localhost:5001
# (Optional. Leave unset to use proxy when backend is on 5000.)

# ── LLM (required for PRD / UAT / BRD agents) ──
LLM_KEY_API=
# or
LLM_API_KEY=
LLM_MODEL=pi-agentic/global-anthropic-claude-opus-4-5-20251101-v1-0
# Optional: override gateway URL
# LLM_URL=https://your-llm-gateway.com/api/llm/messages

# ── JIRA (optional, for BRD JIRA fetch) ──
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_TOKEN=
# or JIRA_API_TOKEN=

# ── Cursor MCP (optional; not read by Node — export same vars for ~/.cursor/mcp.json)
# See docs/CURSOR_MCP.md — keep secrets out of mcp.json, use ~/.cursor/mcp-secrets.env
# CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki
# CONFLUENCE_USERNAME=you@company.com
# CONFLUENCE_API_TOKEN=   # often same as JIRA_TOKEN on Atlassian Cloud
# REDASH_URL=https://your-redash.example.com
# REDASH_API_KEY=

# ── Connectors (optional) ──
# SLACK_BOT_TOKEN= or SLACK_WEBHOOK_URL=
# WHATSAPP_TOKEN= and WHATSAPP_PHONE_ID=
# EMAIL_SMTP_HOST= and EMAIL_API_KEY=
# TELEGRAM_BOT_TOKEN=

# ── Server (backend port; frontend proxy points at 5000) ──
# PORT=5000
# NODE_ENV=production
# If you change PORT here, set REACT_APP_API_URL=http://localhost:YOUR_PORT in the repo root .env.

# ── RAG / Smart Context Engine (optional; see docs/SMART_CONTEXT_ENGINE.md) ──
# RAG_ENABLED=true
# OPENAI_API_KEY=

# ── Share (JIRA comment, Telegram, Email) — uses JIRA_* and TELEGRAM_BOT_TOKEN above ──
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USER=your@email.com
# EMAIL_PASS=app-password
# EMAIL_FROM=noreply@yourdomain.com

# ── Score (PRD/UAT/BRD) — uses OpenAI (e.g. GPT 5.4 when available) ──
# OPENAI_API_KEY=   # same as above if already set
# SCORE_MODEL=gpt-4o   # or gpt-5.4 when available

# ── Auto-notify on completion (Email + Slack + WhatsApp + Telegram) ──
# When a PRD/UAT/BRD is generated, a notification is sent automatically.
# Format: "<Agent Name> — <JIRA ID / Subject> is done"
# NOTIFY_EMAIL=team@company.com          # defaults to EMAIL_USER if unset
# SLACK_WEBHOOK_URL=                      # same as connectors above
# WHATSAPP_NOTIFY_NUMBER=919876543210     # WhatsApp recipient (with country code, no +)
# TELEGRAM_NOTIFY_CHAT_ID=               # Telegram chat ID for notifications
