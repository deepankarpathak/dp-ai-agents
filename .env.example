# Copy to .env and fill in values. Do not commit .env.

# ── Frontend → Backend (fix "Backend error: 404" on Share / Connectors) ──
# Share, Score, and JIRA APIs are in backend/server.js — run: npm run start:backend
# Or both: npm run dev
# In development, the app defaults to http://127.0.0.1:5000 for API calls (see src/config.js).
# If the backend uses another port:
# REACT_APP_API_URL=http://127.0.0.1:5001
# Optional proxy target for src/setupProxy.js (rarely needed):
# REACT_APP_PROXY_TARGET=http://127.0.0.1:5000

# ── LLM (required for PRD / UAT / BRD agents) ──
LLM_KEY_API=
# or
LLM_API_KEY=
LLM_MODEL=azure-paytm-east-us2/gpt-5
# Optional: override gateway URL
# LLM_URL=https://your-llm-gateway.com/api/llm/messages

# ── JIRA (optional, for BRD JIRA fetch) ──
JIRA_URL=https://yourcompany.atlassian.net
# Second Atlassian Cloud site (e.g. TPAP on mypaytm) — same JIRA_EMAIL / JIRA_TOKEN unless you split creds later.
# JIRA_URL_2=https://mypaytm.atlassian.net
# Project keys that exist only on JIRA_URL_2 (comma-separated). Create + fetch-by-key use this site when jiraSite is "auto".
# JIRA_SECONDARY_PROJECT_KEYS=TPAP,PCO,TPG
JIRA_EMAIL=you@company.com
JIRA_TOKEN=
# or JIRA_API_TOKEN=
#
# JIRA Agent — required custom field "Dev assignee" (default field id below; override if yours differs)
# JIRA_DEV_ASSIGNEE_FIELD_ID=customfield_10236
# Multi-user picker → API expects [{ "id": "712020:…" }] (default). Do NOT set SINGLE_USER_OBJECT unless the field is single-user.
# If you see "data was not an array", ensure JIRA_DEV_ASSIGNEE_SINGLE_USER_OBJECT is unset/false, then restart the backend.
# For a single-user custom field only:
# JIRA_DEV_ASSIGNEE_SINGLE_USER_OBJECT=true
# Prefer email or display name (resolved via /user/search):
# JIRA_DEV_ASSIGNEE=you@company.com
# Or set Atlassian accountId (UUID) directly:
# JIRA_DEV_ASSIGNEE_ACCOUNT_ID=

# ── Cursor MCP (optional; not read by Node — export same vars for ~/.cursor/mcp.json)
# See docs/CURSOR_MCP.md — keep secrets out of mcp.json, use ~/.cursor/mcp-secrets.env
# CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki
# CONFLUENCE_USERNAME=you@company.com
# CONFLUENCE_API_TOKEN=   # often same as JIRA_TOKEN on Atlassian Cloud
# REDASH_URL=https://your-redash.example.com
# REDASH_API_KEY=

# ── Connectors (optional) ──
# SLACK_BOT_TOKEN= or SLACK_WEBHOOK_URL=
# WHATSAPP_TOKEN= and WHATSAPP_PHONE_ID=
# EMAIL_SMTP_HOST= and EMAIL_API_KEY=
# TELEGRAM_BOT_TOKEN=
# If Node reports "unable to get local issuer certificate" calling api.telegram.org (corporate SSL inspection), use only in dev:
# TELEGRAM_INSECURE_TLS=true

# ── Server (backend port; frontend proxy points at 5000) ──
# PORT=5000
# NODE_ENV=production
# If you change PORT here, set REACT_APP_API_URL=http://localhost:YOUR_PORT in the repo root .env.

# ── RAG / Smart Context Engine (optional; see docs/SMART_CONTEXT_ENGINE.md) ──
# RAG_ENABLED=true
# OPENAI_API_KEY=

# ── Share (JIRA comment, Telegram, Email) — uses JIRA_* and TELEGRAM_BOT_TOKEN above ──
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USER=your@email.com
# EMAIL_PASS=app-password
# EMAIL_FROM=noreply@yourdomain.com

# ── Score (“Get score” in Share & Score) — read by backend from repo root .env or backend/.env ──
# Create a key: https://platform.openai.com/api-keys — paste the secret (starts with sk-…)
# OPENAI_API_KEY=sk-proj-...
# SCORE_MODEL=gpt-4o

# ── Auto-notify on completion (Email + Slack + WhatsApp + Telegram) ──
# When a PRD/UAT/BRD is generated, a notification is sent automatically.
# Subject line (when app sends notifySubject): <JIRAID>-<UAT|PRD|BRD>-<title>-<ISO-timestamp>
# NOTIFY_EMAIL=team@company.com          # defaults to EMAIL_USER if unset
#
# JIRA Agent — email when issues are created (parent-only or parent + sub-JIRAs). Requires EMAIL_* SMTP like Share email.
# Recipient (falls back to NOTIFY_EMAIL, then EMAIL_USER):
# JIRA_CREATE_NOTIFY_TO=you@company.com
# Greeting line in the HTML body (default: Deepankar):
# JIRA_CREATE_GREETING_NAME=Deepankar
# SLACK_WEBHOOK_URL=                      # same as connectors above
# WHATSAPP_NOTIFY_NUMBER=919876543210     # WhatsApp recipient (with country code, no +)
# TELEGRAM_NOTIFY_CHAT_ID=               # Telegram chat ID for notifications
